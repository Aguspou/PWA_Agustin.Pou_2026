<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Guitar Vault</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <link rel="icon" href="/favicon.ico">
    <style>
        :root {
            --naranja: #ff6b35;
            --amarillo: #f7b731;
        }

        .text-marca {
            color: var(--naranja) !important;
        }

        .text-amarillo {
            color: var(--amarillo) !important;
        }

        .border-marca {
            border-color: var(--naranja) !important;
        }

        .nav-link.active {
            color: var(--naranja) !important;
        }

        .tarjeta-dato {
            border-left: 4px solid var(--naranja);
        }
    </style>
</head>
<body class="bg-dark text-white">
    <nav class="navbar navbar-expand-lg navbar-dark bg-black border-bottom border-marca fixed-top">   <!-- nav principal -->
        <div class="container">
            <a class="navbar-brand fw-bold fs-4 text-marca" asp-controller="Home" asp-action="Index">
                GUITAR<span class="text-amarillo">VAULT</span>
            </a>
            <button class="navbar-toggler" type="button"
                    data-bs-toggle="collapse" data-bs-target="#menuNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="menuNav">
                <ul class="navbar-nav ms-auto gap-1">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">Inicio</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Tipos">Tipos</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Historia">Historia</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Curiosidades">Curiosidades</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Contacto">Contacto</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Guitarra" asp-action="Index">Guitarra</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <main class="pt-5 mt-3">
        @RenderBody()
    </main> 

    <footer class="bg-black border-top border-marca py-4 mt-5 text-center">
        <p class="text-secondary mb-0">
            © 2024 <span class="text-marca fw-bold">GUITAR VAULT</span> — Proyecto Educativo sobre Guitarras
        </p>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>